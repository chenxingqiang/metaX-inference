{
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 19001,
    "auth": {
      "mode": "token",
      "token": "REPLACE_GATEWAY_TOKEN"
    },
    "controlUi": {
      "allowInsecureAuth": true,
      "allowedOrigins": [
        "http://127.0.0.1:19001",
        "http://localhost:19001",
        "http://127.0.0.1:8080",
        "http://localhost:8080"
      ]
    }
  },
  "plugins": {
    "entries": {
      "trustclaw-tra": {
        "enabled": true,
        "config": {
          "agentPacksDir": "REPLACE_AGENT_PACKS_DIR",
          "defaultAgentPack": "glp1-eligibility"
        }
      },
      "acpx": {
        "enabled": false
      },
      "workboard": {
        "enabled": true
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "vllm/REPLACE_VLLM_MODEL_ID",
        "fallbacks": []
      },
      "models": {
        "vllm/REPLACE_VLLM_MODEL_ID": {
          "alias": "qwen36-awq",
          "params": {
            "chat_template_kwargs": {
              "enable_thinking": false
            }
          }
        },
        "vllm/*": {}
      },
      "workspace": "REPLACE_STATE_DIR/workspace",
      "compaction": {
        "mode": "safeguard"
      }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "workspace": "REPLACE_STATE_DIR/workspace",
        "agentDir": "REPLACE_STATE_DIR/agents/main/agent"
      }
    ]
  },
  "models": {
    "providers": {
      "vllm": {
        "baseUrl": "REPLACE_VLLM_BASE_URL",
        "apiKey": "${VLLM_API_KEY}",
        "api": "openai-completions",
        "timeoutSeconds": 300,
        "request": {
          "allowPrivateNetwork": true
        },
        "models": [
          {
            "id": "REPLACE_VLLM_MODEL_ID",
            "name": "Qwen3.6-27B-AWQ (MetaX vLLM)",
            "reasoning": false,
            "input": ["text"],
            "compat": {
              "thinkingFormat": "qwen-chat-template"
            },
            "cost": {
              "input": 0,
              "output": 0,
              "cacheRead": 0,
              "cacheWrite": 0
            },
            "contextWindow": 8192,
            "maxTokens": 4096
          }
        ]
      }
    }
  },
  "env": {
    "VLLM_API_KEY": "REPLACE_VLLM_API_KEY"
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto"
  }
}
