# MetaX 完整栈运行配置（复制为 app.env）
# cp docker/metax-full/app.env.example docker/metax-full/app.env

# 宿主机映射
APP_PORT=19001
VLLM_PORT=8000

# Gateway 访问令牌（请改成强随机值）
OPENCLAW_GATEWAY_TOKEN=change-me-trustclaw-metax

# vLLM
VLLM_API_KEY=sk-unsloth-metax-docker-change-me
MODEL=/data/models/Qwen3.6-27B-AWQ
VLLM_MODEL_ID=/data/models/Qwen3.6-27B-AWQ
MAX_MODEL_LEN=8192
GPU_MEM=0.92
MAX_SEQS=64
MAX_BATCHED=8192

# TrustClaw
OPENCLAW_PRIMARY_MODEL=vllm//data/models/Qwen3.6-27B-AWQ
TRUSTCLAW_DEFAULT_AGENT_PACK=glp1-eligibility
VLLM_BASE_URL=http://vllm:8000/v1

# 宿主机路径（MetaX 实机默认）
MODELS_DIR=/data/models
MACA_DIR=/opt/maca
MXDRIVER_DIR=/opt/mxdriver
CONDA_DIR=/opt/conda

TZ=Asia/Shanghai
